{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; media-src 'self' blob: https://audio.lang5k.com; connect-src 'self' https://api.stripe.com https://audio.lang5k.com; frame-src https://checkout.stripe.com; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(self), geolocation=(), payment=(self)"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://www.lang5k.com"
        }
      ]
    }
  ],
  "functions": {
    "api/preview-page.js": {
      "includeFiles": "*.html"
    },
    "api/admin-report.js": {
      "includeFiles": "admin-status.json"
    }
  },
  "routes": [
    {
      "src": "^/api/teacher-voice$",
      "dest": "/api/course?voice=teacher"
    },
    {
      "src": "^/$",
      "dest": "/api/preview-page?file=index.html"
    },
    {
      "src": "^/index\\.html$",
      "dest": "/api/preview-page?file=index.html"
    },
    {
      "src": "^/app\\.html$",
      "dest": "/api/preview-page?file=app.html"
    },
    {
      "src": "^/access\\.html$",
      "dest": "/api/preview-page?file=access.html"
    },
    {
      "src": "^/admin\\.html$",
      "dest": "/api/preview-page?file=admin.html"
    },
    {
      "src": "^/attribution\\.html$",
      "dest": "/api/preview-page?file=attribution.html"
    },
    {
      "src": "^/checkout\\.html$",
      "dest": "/api/preview-page?file=checkout.html"
    },
    {
      "src": "^/contact\\.html$",
      "dest": "/api/preview-page?file=contact.html"
    },
    {
      "src": "^/pricing\\.html$",
      "dest": "/api/preview-page?file=pricing.html"
    },
    {
      "src": "^/privacy\\.html$",
      "dest": "/api/preview-page?file=privacy.html"
    },
    {
      "src": "^/refund\\.html$",
      "dest": "/api/preview-page?file=refund.html"
    },
    {
      "src": "^/terms\\.html$",
      "dest": "/api/preview-page?file=terms.html"
    }
  ]
}
